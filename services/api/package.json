{
  "name": "@bat-dating/api",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "TMPDIR=/tmp TMP=/tmp TEMP=/tmp tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "bash ./scripts/test-integration.sh",
    "test:integration": "bash ./scripts/test-integration.sh",
    "db:up": "bash ./scripts/db-up.sh",
    "db:down": "bash ./scripts/db-down.sh",
    "prisma:generate": "dotenv -e .env -- prisma generate --schema ../../prisma/schema.prisma",
    "prisma:db:push": "dotenv -e .env -- prisma db push --schema ../../prisma/schema.prisma",
    "prisma:migrate:dev": "dotenv -e .env -- prisma migrate dev --schema ../../prisma/schema.prisma",
    "prisma:seed": "TMPDIR=/tmp TMP=/tmp TEMP=/tmp dotenv -e .env -- tsx src/scripts/seed.ts",
    "db:reset:seed": "npm run prisma:db:push && npm run prisma:seed"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "firebase-admin": "^13.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
